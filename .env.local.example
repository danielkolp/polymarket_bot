# Polymarket copy-trading dashboard/bot configuration
# Copy to .env.local if you want to override defaults.

NEXT_PUBLIC_APP_NAME=Polymarket Copy Bot

# Read-only Polymarket upstream APIs. These are used in simulation mode too.
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_LB_URL=https://lb-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com
POLY_REQUEST_TIMEOUT_MS=8000

# ─── Real-money trading (Polymarket CLOB) ─────────────────────────────────────
# DANGER: ENABLE_REAL_TRADING=true makes the bot place REAL orders with REAL
# USDC, fully automatically, copying other wallets' trades. Leave it false until
# you have funded a wallet and tested with a tiny LIVE_MAX_ORDER_USD.
ENABLE_REAL_TRADING=false

# EIP-712 signing key for the trading wallet (ethers v5). SERVER-ONLY — never
# commit this and never expose it to the browser. Required for live orders.
POLYMARKET_PRIVATE_KEY=

# Wallet that holds the USDC. Leave blank for a plain EOA (defaults to the signer
# address). For a Polymarket proxy/email wallet or Gnosis safe, set the proxy
# address here and the matching signature type below.
POLYMARKET_FUNDER_ADDRESS=
# 0 = EOA, 1 = Polymarket proxy wallet, 2 = Polymarket Gnosis safe.
POLYMARKET_SIGNATURE_TYPE=0

# Polygon mainnet = 137 (live), Amoy testnet = 80002.
POLYMARKET_CHAIN_ID=137

# Hard per-order USD backstop. Every live BUY is clamped to this regardless of
# the percentage sizing / exposure caps. Start tiny (e.g. 1) and raise on purpose.
LIVE_MAX_ORDER_USD=5

# Safety: when true (default), a persisted PANIC STOP is NOT cleared on restart —
# the operator must explicitly resume. Prevents a crash/restart from silently
# re-enabling live trading after an emergency stop.
LIVE_REQUIRE_MANUAL_RESUME_AFTER_PANIC=true

# Block placing NEW live orders once this many previously-placed live orders are
# still unreconciled against authoritative CLOB fills. Keeps the local ledger
# from drifting from on-chain truth. Set 0 to disable the guard.
LIVE_MAX_UNRECONCILED_ORDERS=5

# A real BUY still pending reconciliation after this many seconds blocks new BUYs.
LIVE_PENDING_STALE_SECONDS=60

# Allow heuristic (non-order-id) reconciliation matching. OFF by default: in real
# money mode only exact order-id matches are trusted; anything else is surfaced as
# unmatched for manual review rather than guessed.
LIVE_ALLOW_FUZZY_RECONCILE=false

# How many pages of CLOB trade history to walk when reconciling (safety cap).
LIVE_RECONCILE_MAX_PAGES=10

# Block new BUYs once the live-position snapshot is older than this many seconds.
LIVE_POSITIONS_STALE_SECONDS=120

# ─── Dashboard security ───────────────────────────────────────────────────────
# Optional shared secret protecting every MUTATING API route (start/stop/reset/
# settings/traders/panic/...). When set, requests must send it via the
# `x-dashboard-token` header or `dashboard_token` cookie. Same-origin (CSRF)
# checks and per-client rate limiting apply regardless. Leave blank only for
# trusted localhost dev.
DASHBOARD_AUTH_TOKEN=
